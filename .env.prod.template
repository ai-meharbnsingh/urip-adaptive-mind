# .env.prod.template — copy to .env.prod and fill in secrets before deploying.
# .env.prod is gitignored; this template is committed and documents all required vars.

# ── Application ──────────────────────────────────────────────────────────────
URIP_ENV=production
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
ALLOWED_HOSTS=urip.adaptive-mind.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<strong-random-password>
DATABASE_URL=postgresql+asyncpg://urip:${POSTGRES_PASSWORD}@db:5432/urip
DATABASE_URL_SYNC=postgresql://urip:${POSTGRES_PASSWORD}@db:5432/urip

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Rate limiting (Gemini MEDIUM fix) ────────────────────────────────────────
# REQUIRED for prod: keeps rate-limit counters across restarts + across workers.
# Using db=1 to isolate rate-limit data from Celery broker (db=0).
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://urip.adaptive-mind.com

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Trusted proxies (nginx → app) ─────────────────────────────────────────────
TRUSTED_PROXY_IPS=172.16.0.0/12

# ── Log shipping (Gemini MEDIUM fix) ─────────────────────────────────────────
# Option A: Syslog (rsyslog / syslog-ng running on same host)
# URIP_SYSLOG_HOST=127.0.0.1
# URIP_SYSLOG_PORT=514
#
# Option B: Loki push
# URIP_LOKI_URL=http://loki:3100/loki/api/v1/push

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@urip.adaptive-mind.com
SMTP_PASSWORD=<smtp-password>
