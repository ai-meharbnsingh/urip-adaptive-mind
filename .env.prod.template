# .env.prod.template — production environment variables for URIP-Adaptive Mind.
#
# Copy this file to .env.prod on your production host (gitignored), fill in
# real secrets, and pass --env-file .env.prod to docker compose.

# ─── Environment marker ─────────────────────────────────────────────────────
URIP_ENV=production

# ─── JWT (rotate on every prod deploy) ──────────────────────────────────────
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(64))'
# Backend refuses to start if URIP_ENV=production and JWT_SECRET_KEY is the
# well-known dev default ("urip-dev-secret-change-in-production").
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://urip:${POSTGRES_PASSWORD}@db:5432/urip
DATABASE_URL_SYNC=postgresql://urip:${POSTGRES_PASSWORD}@db:5432/urip
COMPLIANCE_DB_URL=postgresql+asyncpg://urip:${POSTGRES_PASSWORD}@db:5432/urip_compliance

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS (comma-separated origins; no wildcards in prod) ───────────────────
CORS_ORIGINS=https://urip.adaptive-mind.com,https://api.urip.adaptive-mind.com

# ─── Compliance auth mode ───────────────────────────────────────────────────
# INTEGRATED = compliance backend verifies URIP-issued JWTs (single sign-on).
# STANDALONE = compliance backend issues+verifies its own JWTs.
COMPLIANCE_AUTH_MODE=INTEGRATED
URIP_JWT_SECRET=${JWT_SECRET_KEY}
COMPLIANCE_JWT_SECRET=

# ─── Encryption key for tenant credential vault (Fernet 32-byte b64) ────────
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
URIP_FERNET_KEY=

# ─── Distributed events + Redis-backed notifications ────────────────────────
# Set both to enable cross-pod event delivery + durable notifications.
URIP_DISTRIBUTED_EVENTS=1
URIP_NOTIFICATION_BACKEND=redis  # or "memory" to opt out (only for tests)

# ─── Rate limiting (Redis-backed; resets on restart if memory://) ───────────
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1

# ─── Observability — optional log shipping ──────────────────────────────────
# Uncomment to ship logs to a SysLog target.
# URIP_SYSLOG_HOST=syslog.your-org.com
# URIP_SYSLOG_PORT=514
# URIP_LOKI_URL=https://loki.your-org.com/loki/api/v1/push

# ─── Bootstrap admin (used by scripts/bootstrap_dev.py only) ────────────────
URIP_DEV_ADMIN_PASSWORD=
