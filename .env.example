# URIP Environment Configuration
# Copy this file to `.env` and fill real values for local dev.
# Before deploying to staging or production, you MUST rotate every secret
# below (especially JWT_SECRET_KEY) and set URIP_ENV=production.
#
# ─── SECRETS ROTATION PROCEDURE ──────────────────────────────────────────
# Production secrets MUST live in a secrets manager (AWS Secrets Manager,
# HashiCorp Vault, Doppler, 1Password Secrets Automation), NEVER on disk.
#
# Before first run:
#   1. Generate a strong JWT secret:
#        python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
#   2. Generate a Fernet key for credential encryption:
#        python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#   3. Inject both via your secrets manager / orchestrator env vars.
#   4. Set URIP_ENV=production. Backend refuses to start with the dev
#      default `urip-dev-secret-change-in-production` in production-like
#      envs (URIP_ENV in {prod, production, staging}).
#
# If a credential is suspected leaked:
#   1. Rotate immediately at the source (Neon console, IAM, etc.).
#   2. Generate a new JWT_SECRET_KEY — this invalidates ALL existing tokens.
#   3. Audit DB query logs / access logs for unauthorised access.
#   4. Re-deploy with the new secrets.
#
# DO NOT commit `.env`, `.env.production`, or any `.credentials.*` file
# to git. These patterns are blocked by `.gitignore` for this reason.
# ──────────────────────────────────────────────────────────────────────────

# Set to: dev | development | staging | production | prod
# In staging / prod the backend REFUSES TO START if JWT_SECRET_KEY is empty
# or equal to the well-known dev default.
URIP_ENV=dev

DATABASE_URL=postgresql+asyncpg://urip:urip_dev@localhost:5432/urip

# !!! ROTATE BEFORE PRODUCTION !!!
# This default value is the well-known dev secret. The backend will refuse to
# start if URIP_ENV is staging/production and this value is left unchanged.
# Generate a strong secret, e.g.:  python -c 'import secrets; print(secrets.token_urlsafe(64))'
# The placeholder string `urip-dev-secret-change-in-production` is the well-known
# dev default — DO NOT use it in any production-like deployment.
# Leave empty here — the backend falls back to the well-known dev default
# in URIP_ENV=development only. Generate a real secret with the command above
# before copying this file to .env for any other environment.
JWT_SECRET_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# !!! ROTATE BEFORE PRODUCTION !!!
URIP_FERNET_KEY=your-fernet-key-here

CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Connector API Keys (populated when Royal Enfield provides access)
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
ARMIS_API_KEY=
ZSCALER_API_KEY=
CYBERARK_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
JIRA_URL=
JIRA_API_TOKEN=
SERVICENOW_URL=
SERVICENOW_API_TOKEN=
